---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPostBySlug } from '../../lib/pages';
import type { BlogPost } from '../../lib/pages';
import { marked } from 'marked';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=600, stale-while-revalidate=86400'
);

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

if (slug.includes('.')) {
  return new Response(null, { status: 404 });
}

let post: BlogPost | null = null;

try {
  post = await getBlogPostBySlug(slug);
} catch (error) {
  console.error('[Blog Post] Error loading:', error);
}

if (!post) {
  return Astro.redirect('/404');
}

const title = post.title;
const description = post.metaDescription || post.excerpt || post.title;
const canonical = `https://imprimearte.es/blog/${post.slug}`;
const parsedContent = marked(post.content);

const publishedDate = post.publishedAt
  ? new Date(post.publishedAt.seconds * 1000).toISOString()
  : null;
const modifiedDate = post.updatedAt
  ? new Date(post.updatedAt.seconds * 1000).toISOString()
  : publishedDate;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: post.featuredImage || undefined,
  datePublished: publishedDate,
  dateModified: modifiedDate,
  author: {
    '@type': 'Organization',
    name: post.author || 'ImprimeArte',
  },
  publisher: {
    '@type': 'Organization',
    name: 'ImprimeArte',
    logo: {
      '@type': 'ImageObject',
      url: 'https://imprimearte.es/logoFac.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={post.featuredImage || undefined}
  canonical={canonical}
  schema={schema}
>
  <div class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm">
        <ol class="flex items-center gap-2 text-gray-600">
          <li><a href="/" class="hover:text-cyan-600">Inicio</a></li>
          <li class="text-gray-400">/</li>
          <li><a href="/blog" class="hover:text-cyan-600">Blog</a></li>
          <li class="text-gray-400">/</li>
          <li class="text-gray-900 font-medium truncate max-w-[60%]">{post.title}</li>
        </ol>
      </nav>

      <!-- Header -->
      <article class="bg-white rounded-2xl shadow-lg p-8 mb-8">
        {
          post.featuredImage && (
            <img
              src={post.featuredImage}
              alt={post.title}
              class="w-full h-64 md:h-96 object-cover rounded-xl mb-6"
              loading="eager"
              fetchpriority="high"
            />
          )
        }

        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{post.title}</h1>

        <div class="flex items-center gap-6 text-sm text-gray-600 mb-6">
          {
            post.author && (
              <div class="flex items-center gap-2">
                <span class="font-semibold">Por {post.author}</span>
              </div>
            )
          }
          {
            post.publishedAt && (
              <div class="flex items-center gap-2">
                <span>📅</span>
                <span>
                  {new Date(post.publishedAt.seconds * 1000).toLocaleDateString('es-ES', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </span>
              </div>
            )
          }
        </div>

        <!-- Content -->
        <div
          class="blog-content prose prose-lg max-w-none
          prose-headings:font-bold prose-headings:text-gray-900
          prose-h1:text-4xl prose-h1:mb-6
          prose-h2:text-3xl prose-h2:mt-8 prose-h2:mb-4
          prose-h3:text-2xl prose-h3:mt-6 prose-h3:mb-3
          prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-4
          prose-strong:text-gray-900 prose-strong:font-bold
          prose-ul:list-disc prose-ul:ml-6
          prose-ol:list-decimal prose-ol:ml-6
          prose-li:text-gray-700 prose-li:mb-2
          prose-img:rounded-xl prose-img:my-6
          prose-blockquote:border-l-4 prose-blockquote:border-cyan-500 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:bg-cyan-50 prose-blockquote:py-2 prose-blockquote:rounded-r-lg"
          set:html={parsedContent}
        />

        <style is:global>
          /* Links blog: paleta marca cyan / magenta / amber rotativos */
          .blog-content a {
            color: #0891b2; /* cyan-600 */
            text-decoration: none;
            background-image: linear-gradient(120deg, #06b6d4 0%, #d946ef 50%, #f59e0b 100%);
            background-repeat: no-repeat;
            background-size: 100% 2px;
            background-position: 0 100%;
            padding-bottom: 2px;
            transition: color 0.2s ease, background-size 0.3s ease;
            font-weight: 600;
          }
          .blog-content a:hover {
            color: #d946ef; /* fuchsia-500 magenta */
            background-size: 100% 3px;
          }
          .blog-content a:visited {
            color: #0e7490; /* cyan-700 */
          }
        </style>
      </article>

      <!-- Back Button -->
      <div class="text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-3 bg-cyan-600 text-white font-semibold rounded-xl hover:bg-cyan-700 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width={2}
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Volver al blog
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
