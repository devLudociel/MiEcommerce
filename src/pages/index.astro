---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/sections/HeroCarousel.tsx';
import CategoriesShowcase from '../components/sections/CategoriesShowcase.tsx';
import BestSellersWithProvider from '../components/sections/BestSellersWithProvider.tsx';
import ProductGrid from '../components/sections/ProductGrid.tsx';
import ReadyToBuyHomeWithProvider from '../components/sections/ReadyToBuyHomeWithProvider.tsx';
import DigitalProductsHomeWithProvider from '../components/sections/DigitalProductsHomeWithProvider.tsx';
import CustomerReviews from '../components/sections/CustomerReviews.tsx';
import ContactWhatsApp from '../components/sections/ContactWhatsApp.tsx';
import FooterComponent from '../components/sections/Footer.tsx';

// SEO Optimizado
const title = 'ImprimeArte - Estampado, Bordado e Impresión 3D Personalizada';
const description = 'Servicios profesionales de personalización en Los Llanos de Aridane: estampado textil, bordado, impresión 3D en resina y filamento, corte láser, sublimación. Calidad premium, precios desde €2. ¡Envío a toda Canarias!';
const ogImage = '/og-home.jpg';
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <!-- 1. Hero: split layout editorial con tarjetas producto -->
  <HeroCarousel client:load />

  <!-- 2. Qué hacemos: grid numerado de categorías -->
  <CategoriesShowcase client:load />

  <!-- 3. Lo más pedido esta semana -->
  <BestSellersWithProvider client:visible />

  <!-- 4. Productos físicos destacados -->
  <ProductGrid client:visible />

  <!-- 5. Diseños listos para comprar -->
  <ReadyToBuyHomeWithProvider client:visible maxItems={6} />

  <!-- 6. Productos digitales descargables -->
  <DigitalProductsHomeWithProvider client:visible maxItems={4} />

  <!-- 7. Que dicen nuestros clientes — sección oscura -->
  <CustomerReviews client:visible />

  <!-- 8. Contacto + Newsletter fusionados -->
  <ContactWhatsApp client:visible />

  <!-- 9. Footer -->
  <footer class="bg-gray-800 text-white py-12">
    <FooterComponent client:only="react" />
  </footer>
</BaseLayout>
