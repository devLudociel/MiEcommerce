---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/sections/HeroCarousel.tsx';
import CategoriesShowcase from '../components/sections/CategoriesShowcase.tsx';
import BestSellersWithProvider from '../components/sections/BestSellersWithProvider.tsx';
import ProductGrid from '../components/sections/ProductGrid.tsx';
import ReadyToBuyHomeWithProvider from '../components/sections/ReadyToBuyHomeWithProvider.tsx';
import DigitalProductsHomeWithProvider from '../components/sections/DigitalProductsHomeWithProvider.tsx';
import CustomerReviews from '../components/sections/CustomerReviews.tsx';
import ContactWhatsApp from '../components/sections/ContactWhatsApp.tsx';
import FooterComponent from '../components/sections/Footer.tsx';

// SEO Optimizado
const title = 'ImprimeArte - Estampado, Bordado e Impresión 3D Personalizada';
const description = 'Servicios profesionales de personalización en Los Llanos de Aridane: estampado textil, bordado, impresión 3D en resina y filamento, corte láser, sublimación. Calidad premium, precios desde €2. ¡Envío a toda Canarias!';
const ogImage = '/og-home.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://imprimearte.es/#business",
      "name": "ImprimeArte",
      "description": "Especialistas en personalización textil, bordado, impresión 3D, corte láser y sublimación en Los Llanos de Aridane, La Palma.",
      "url": "https://imprimearte.es",
      "telephone": "+34 643 037 152",
      "email": "info@imprimearte.es",
      "image": "https://imprimearte.es/logoFac.png",
      "logo": "https://imprimearte.es/logoFac.png",
      "priceRange": "€€",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Cash, Credit Card, Transfer",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Los Llanos de Aridane",
        "addressLocality": "Los Llanos de Aridane",
        "addressRegion": "La Palma",
        "postalCode": "38760",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 28.658,
        "longitude": -17.917
      },
      "areaServed": [
        { "@type": "Place", "name": "La Palma" },
        { "@type": "Place", "name": "Canarias" },
        { "@type": "Place", "name": "España" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de personalización",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Estampado textil DTF" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bordado personalizado" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Impresión 3D en resina y filamento" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Corte láser" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sublimación" } }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "worstRating": "1",
        "ratingCount": "16"
      },
      "sameAs": [
        "https://www.instagram.com/imprimearte.es"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://imprimearte.es/#website",
      "url": "https://imprimearte.es",
      "name": "ImprimeArte",
      "description": "Servicios profesionales de personalización en La Palma, Canarias",
      "inLanguage": "es-ES",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://imprimearte.es/productos?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  ]
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} schema={schema}>
  <!-- 1. Hero: split layout editorial con tarjetas producto -->
  <HeroCarousel client:load />

  <!-- 2. Qué hacemos: grid numerado de categorías -->
  <CategoriesShowcase client:load />

  <!-- 3. Lo más pedido esta semana -->
  <BestSellersWithProvider client:visible />

  <!-- 4. Productos físicos destacados -->
  <ProductGrid client:visible />

  <!-- 5. Diseños listos para comprar -->
  <ReadyToBuyHomeWithProvider client:visible maxItems={6} />

  <!-- 6. Productos digitales descargables -->
  <DigitalProductsHomeWithProvider client:visible maxItems={4} />

  <!-- 7. Que dicen nuestros clientes — sección oscura -->
  <CustomerReviews client:visible />

  <!-- 8. Contacto + Newsletter fusionados -->
  <ContactWhatsApp client:visible />

  <!-- 9. Footer -->
  <footer class="bg-gray-800 text-white py-12">
    <FooterComponent client:only="react" />
  </footer>
</BaseLayout>
