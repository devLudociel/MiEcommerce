---
import Layout from '../../layouts/BaseLayout.astro';
import CategoryPageOptimized from '../../components/pages/CategoryPageOptimized';

export const prerender = false; // Habilita SSR para esta página

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=300, stale-while-revalidate=86400'
);

const { slug } = Astro.params;
const slugArray = slug ? slug.split('/') : [];
const categorySlug = slugArray[0];
const subcategorySlug = slugArray[1];
---

<Layout title={`Categoría`}>
  <CategoryPageOptimized categorySlug={categorySlug} subcategorySlug={subcategorySlug} client:load />
</Layout>
